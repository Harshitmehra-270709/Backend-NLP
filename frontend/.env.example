# ===========================================
# FRONTEND ENVIRONMENT CONFIGURATION TEMPLATE
# ===========================================
# Copy this file to '.env' and enter your actual settings.
# Notice: 'VITE_' prefix exposes these to the browser.

# Backend connection string (Render URL in production)
VITE_API_URL=http://localhost:8000

# Authentication key matching backend APP_SECRET_KEY
VITE_APP_API_KEY=dev-secret-key-123
