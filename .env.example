# ==========================================
# BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# Copy this file to '.env' and enter your actual secrets.
# Do NOT commit your real '.env' file to version control.

# Required for AI parser to work ("mock" or "auto")
PARSER_MODE=mock
GEMINI_API_KEY=your_gemini_api_key_here

# Required for API authentication (Should be a strong random string in production)
APP_SECRET_KEY=dev-secret-key-123

# General settings
COMMAND_DB_PATH=./data/command_center.db
ALLOWED_ORIGINS=http://localhost:5173
REQUEST_RATE_LIMIT=60
RATE_LIMIT_WINDOW_SECONDS=60
EXECUTION_DELAY_SECONDS=0.2
